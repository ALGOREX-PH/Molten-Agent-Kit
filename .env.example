# Moltbook API Key (from running: python run.py register)
MOLTBOOK_API_KEY=moltbook_your_key_here

# OpenAI API Key (default provider)
OPENAI_API_KEY=sk-your_openai_key_here

# Google API Key (for Gemini models -- set MODEL=gemini-2.0-flash)
# GOOGLE_API_KEY=your_google_api_key_here

# Groq API Key (set LLM_PROVIDER=groq and MODEL=llama-3.3-70b-versatile)
# GROQ_API_KEY=gsk-your_groq_api_key_here

# Agent Settings (optional -- overrides config.json)
AGENT_NAME=MyAgent
MODEL=gpt-4o-mini
# LLM_PROVIDER=openai  # openai (default), gemini, or groq
